# AICQ Server Environment Configuration
# ─────────────────────────────────────────
# This project uses ClickHouse as its database (not SQLite).
# To connect ClickHouse, configure the variables below.

# ClickHouse connection
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=aicq

# Server
# DOMAIN=localhost
# PORT=61018
# JWT_SECRET=<your-secret-key>

# Email verification (configure for production)
# SMTP_HOST=smtp.example.com
# SMTP_USER=your@email.com
# SMTP_PASS=your-password

# SMS verification (configure for production)
# SMS_PROVIDER=twilio
# SMS_API_KEY=your-api-key

