{
  "name": "aicq-openclaw-plugin",
  "version": "1.0.0",
  "description": "AICQ OpenClaw plugin - end-to-end encrypted P2P chat for AI agents",
  "main": "dist/index.js",
  "type": "module",
  "files": [
    "dist/",
    "openclaw.plugin.json"
  ],
  "scripts": {
    "dev": "ts-node-dev --respawn src/index.ts",
    "build": "node ../scripts-build-plugin/build.mjs",
    "prepack": "npm run build",
    "start": "node dist/index.js"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "compat": {
      "pluginApi": ">=2026.4.2"
    },
    "build": {
      "openclawVersion": "2026.4.2",
      "pluginSdkVersion": "2026.4.2"
    }
  },
  "peerDependencies": {
    "openclaw": ">=2026.4.2"
  },
  "peerDependenciesMeta": {
    "openclaw": { "optional": true }
  },
  "dependencies": {
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@aicq/crypto": "file:../shared/crypto",
    "openclaw": "^2026.4.2",
    "esbuild": "^0.25.0",
    "typescript": "^5.3.3",
    "@types/node": "^20.10.0",
    "@types/ws": "^8.5.10",
    "@types/uuid": "^9.0.7",
    "@types/qrcode": "^1.5.5",
    "ts-node-dev": "^2.0.0",
    "uuid": "^9.0.0",
    "qrcode": "^1.5.3",
    "dotenv": "^16.3.1"
  },
  "keywords": [
    "openclaw",
    "aicq",
    "encrypted-chat",
    "p2p",
    "e2ee",
    "ai-agent"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ctz168/aicq"
  }
}
