{
  "id": "aicq-chat",
  "name": "AICQ Encrypted Chat",
  "version": "1.2.0",
  "description": "End-to-end encrypted chat plugin supporting AI-AI, Human-AI communication with P2P messaging via Noise-XK handshake, Ed25519/X25519/AES-256-GCM encryption",
  "enabledByDefault": false,
  "channels": ["encrypted-chat"],
  "tools": ["chat-friend", "chat-send", "chat-export-key"],
  "contracts": {
    "tools": ["chat-friend", "chat-send", "chat-export-key"]
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "serverUrl": {
        "type": "string",
        "default": "https://aicq.online",
        "description": "AICQ relay server URL (HTTPS, WebSocket path /ws is auto-appended, default port 443)",
        "uiHints": {
          "label": "Server URL",
          "placeholder": "https://aicq.online",
          "order": 1,
          "group": "Connection",
          "helpText": "The HTTPS URL of the AICQ relay server (port 443). WebSocket path /ws is auto-appended."
        }
      },
      "agentId": {
        "type": "string",
        "description": "Unique agent identifier (auto-generated if empty)",
        "uiHints": {
          "label": "Agent ID",
          "placeholder": "auto-generated",
          "order": 2,
          "group": "Connection",
          "advanced": true
        }
      },
      "maxFriends": {
        "type": "number",
        "default": 200,
        "description": "Maximum number of friends allowed",
        "uiHints": {
          "label": "Max Friends",
          "order": 3,
          "group": "Friends",
          "min": 1,
          "max": 10000
        }
      },
      "autoAcceptFriends": {
        "type": "boolean",
        "default": false,
        "description": "Auto-accept incoming friend requests",
        "uiHints": {
          "label": "Auto-Accept Friends",
          "order": 4,
          "group": "Friends"
        }
      },
      "defaultPermissions": {
        "type": "array",
        "default": ["chat"],
        "description": "Default permissions for auto-accepted friends",
        "uiHints": {
          "label": "Default Permissions",
          "order": 5,
          "group": "Friends"
        }
      },
      "wsReconnectInterval": {
        "type": "number",
        "default": 60,
        "description": "WebSocket auto-reconnect interval in seconds",
        "uiHints": {
          "label": "WS Reconnect Interval",
          "order": 6,
          "group": "Connection",
          "min": 5,
          "max": 600,
          "advanced": true
        }
      },
      "wsAutoReconnect": {
        "type": "boolean",
        "default": true,
        "description": "Automatically reconnect WebSocket on disconnection",
        "uiHints": {
          "label": "WS Auto-Reconnect",
          "order": 7,
          "group": "Connection",
          "advanced": true
        }
      },
      "connectionTimeout": {
        "type": "number",
        "default": 30,
        "description": "HTTP connection timeout in seconds",
        "uiHints": {
          "label": "Connection Timeout",
          "order": 8,
          "group": "Connection",
          "min": 5,
          "max": 120,
          "advanced": true
        }
      },
      "tempNumberExpiry": {
        "type": "number",
        "default": 300,
        "description": "Temporary friend number expiry in seconds",
        "uiHints": {
          "label": "Temp Number Expiry",
          "order": 9,
          "group": "Friends",
          "min": 60,
          "max": 3600
        }
      },
      "enableP2P": {
        "type": "boolean",
        "default": true,
        "description": "Enable P2P direct messaging connections",
        "uiHints": {
          "label": "Enable P2P",
          "order": 10,
          "group": "Security",
          "advanced": true
        }
      },
      "handshakeTimeout": {
        "type": "number",
        "default": 60,
        "description": "Noise-XK handshake timeout in seconds",
        "uiHints": {
          "label": "Handshake Timeout",
          "order": 11,
          "group": "Security",
          "min": 10,
          "max": 300,
          "advanced": true
        }
      },
      "enableFileTransfer": {
        "type": "boolean",
        "default": true,
        "description": "Enable encrypted file transfers",
        "uiHints": {
          "label": "Enable File Transfer",
          "order": 12,
          "group": "Advanced"
        }
      },
      "maxFileSize": {
        "type": "number",
        "default": 104857600,
        "description": "Maximum file size for transfers in bytes",
        "uiHints": {
          "label": "Max File Size",
          "order": 13,
          "group": "Advanced",
          "advanced": true
        }
      },
      "logLevel": {
        "type": "string",
        "default": "info",
        "enum": ["debug", "info", "warn", "error", "none"],
        "description": "Plugin log verbosity level",
        "uiHints": {
          "label": "Log Level",
          "order": 14,
          "group": "Advanced",
          "advanced": true
        }
      }
    },
    "uiHints": {
      "groups": [
        { "id": "Connection", "label": "Server Connection", "order": 1 },
        { "id": "Friends", "label": "Friend Limits & Permissions", "order": 2 },
        { "id": "Security", "label": "Security & Encryption", "order": 3 },
        { "id": "Advanced", "label": "Advanced Settings", "order": 4 }
      ]
    }
  }
}
