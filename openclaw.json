{
  "agents": {
    "defaults": {
      "workspace": ".aicq-data",
      "model": "openai/gpt-4o",
      "maxConcurrent": 3,
      "compactionMode": "rolling",
      "thinkingDefault": false,
      "subagentMaxConcurrent": 2
    },
    "list": [
      {
        "id": "assistant",
        "name": "AICQ Assistant",
        "default": true,
        "model": "openai/gpt-4o",
        "systemPrompt": "You are an encrypted chat assistant. Help users communicate securely.",
        "workspace": ".aicq-data",
        "tools": ["chat-friend", "chat-send", "chat-export-key"],
        "enabled": true
      },
      {
        "id": "translator",
        "name": "Translator Agent",
        "model": "anthropic/claude-sonnet-4-20250514",
        "systemPrompt": "You are a translation assistant. Translate messages between languages accurately.",
        "workspace": ".aicq-data",
        "tools": ["chat-send"],
        "enabled": true
      }
    ]
  },
  "bindings": [
    {
      "type": "acp",
      "match": { "peer": { "id": "default" } },
      "agentId": "assistant"
    }
  ],
  "auth": {
    "profiles": {
      "openai": {
        "provider": "openai",
        "mode": "api_key"
      },
      "anthropic": {
        "provider": "anthropic",
        "mode": "api_key"
      }
    }
  },
  "env": {
    "vars": {
      "OPENAI_API_KEY": "",
      "ANTHROPIC_API_KEY": ""
    }
  },
  "models": {
    "mode": "merge",
    "defaultModel": "modelscope/step-3.5-flash",
    "providers": {
      "openai": {
        "apiKey": "",
        "baseUrl": "https://api.openai.com/v1",
        "models": [
          { "id": "gpt-4o", "name": "GPT-4o" },
          { "id": "gpt-4o-mini", "name": "GPT-4o Mini" },
          { "id": "gpt-4-turbo", "name": "GPT-4 Turbo" }
        ]
      },
      "anthropic": {
        "apiKey": "",
        "baseUrl": "https://api.anthropic.com",
        "models": [
          { "id": "claude-sonnet-4-20250514", "name": "Claude Sonnet 4" },
          { "id": "claude-opus-4-20250514", "name": "Claude Opus 4" }
        ]
      },
      "deepseek": {
        "apiKey": "",
        "baseUrl": "https://api.deepseek.com/v1",
        "models": [
          { "id": "deepseek-chat", "name": "DeepSeek V3" },
          { "id": "deepseek-reasoner", "name": "DeepSeek R1" }
        ]
      },
      "modelscope": {
        "baseUrl": "https://api-inference.modelscope.cn/v1",
        "apiKey": "ms-3eca52df-ea14-481b-9e72-73b988b612f7",
        "api": "openai-completions",
        "models": [
          {
            "id": "stepfun-ai/Step-3.5-Flash",
            "name": "step-3.5-flash",
            "reasoning": false,
            "input": ["text", "image"],
            "contextWindow": 200000,
            "maxTokens": 16384
          },
          {
            "id": "ZhipuAI/GLM-5",
            "name": "glm5",
            "reasoning": false,
            "input": ["text", "image"],
            "contextWindow": 200000,
            "maxTokens": 16384
          },
          {
            "id": "Minimal/MiniMax-M2.5",
            "name": "minimax-m2.5",
            "reasoning": false,
            "input": ["text", "image"],
            "contextWindow": 128000,
            "maxTokens": 16384
          },
          {
            "id": "moonshotai/Kimi-K2.5",
            "name": "kimi-k2.5",
            "reasoning": false,
            "input": ["text", "image"],
            "contextWindow": 128000,
            "maxTokens": 16384
          }
        ]
      }
    }
  }
}
