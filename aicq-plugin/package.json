    "dotenv": "^16.3.1",
    "openclaw": "^2026.4.2"
  },
  "devDependencies": {
    "typescript": "^5.3.3",
    "@types/node": "^20.10.0",
    "@types/ws": "^8.5.10",
    "@types/uuid": "^9.0.7",
    "@types/qrcode": "^1.5.5",
    "ts-node-dev": "^2.0.0"
  }
}
