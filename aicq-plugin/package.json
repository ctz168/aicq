{
  "name": "@aicq/plugin",
  "version": "1.0.0",
  "description": "AICQ OpenClaw plugin - encrypted chat for AI agents",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "ts-node-dev --respawn src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "dependencies": {
    "@aicq/crypto": "file:../aicq-crypto",
